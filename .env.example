# Example environment variables for LandlordIQ
# Copy this to a file named `.env` in development and fill in real values.

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres)
DB_NAME=landlordiq
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Safaricom M-Pesa (Sandbox credentials)
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_PASSKEY=your_passkey_here
MPESA_SHORTCODE=174379
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CALLBACK_URL=http://localhost:8000/payments/callback/

# Optional: HMAC secret to verify incoming MPesa webhook payloads
# If you set this, the callback handler will expect a signature header and validate the request body.
MPESA_CALLBACK_SECRET=

# Local/testing
TEST_PHONE=2547XXXXXXXX

# Seed defaults (used by management command `seed_test_data`)
SEED_ADMIN_USER=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123

SEED_PROPERTY_NAME=GDC Plaza
SEED_PROPERTY_ADDRESS=Kakamega Central
SEED_UNIT_NUMBER=Suite 101
SEED_UNIT_RENT=25000.00

SEED_TENANT_NAME=John Doe
SEED_TENANT_EMAIL=john@example.com
SEED_TENANT_PHONE=0795285363
SEED_TENANT_NATIONAL_ID=12345678
